{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=bookTracker.db;Cache=Shared"
  },
  "Jwt": {
    "Issuer": "BookTracker",
    "Audience": "BookTracker",
    "ExpiryMinutes": 60
  },
  "OpenLibrary": {
    "BaseUrl": "https://openlibrary.org",
    "TimeoutSeconds": 10
  },
  "Cors": {
    "AllowedOrigin": "http://localhost:3000"
  }
}
